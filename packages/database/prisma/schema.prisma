}

enum CalendarConnectionStatus {
  DISCONNECTED
  PENDING
  ACTIVE
  ERROR
}

enum GovernancePublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConfigurationValueType {
  STRING
  BOOLEAN
  INTEGER
  DECIMAL
}

model User {
  id                           String                        @id @default(uuid()) @db.Uuid
  email                        String                        @unique @db.Citext
  passwordHash                 String                        @map("password_hash")
  emailVerifiedAt              DateTime?                     @map("email_verified_at") @db.Timestamptz(6)
  preferredLocale              String                        @default("vi-VN") @map("preferred_locale")
  accountStatus                AccountStatus                 @default(PENDING_VERIFICATION) @map("account_status")
  failedLoginCount             Int                           @default(0) @map("failed_login_count")
  lockedUntil                  DateTime?                     @map("locked_until") @db.Timestamptz(6)
  deletedAt                    DateTime?                     @map("deleted_at") @db.Timestamptz(6)
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles                        UserRole[]
  sessions                     Session[]
  mfaConfigurations            MfaConfiguration[]
  accountLifecycleTokens       AccountLifecycleToken[]
  memberships                  OrganizationMembership[]
  patientProfile               PatientProfile?
  caregiverGrants              CaregiverGrant[]              @relation("CaregiverUser")
  caseAssignments              CaseAssignment[]              @relation("AssignedUser")
  statusChanges                CaseStatusHistory[]           @relation("CaseStatusActor")
  auditLogs                    AuditLog[]                    @relation("AuditActor")
  impersonatedAudits           AuditLog[]                    @relation("AuditImpersonator")
  consentRecords               ConsentRecord[]
  authoredMessages             Message[]                     @relation("MessageAuthor")
  internalNotes                InternalNote[]                @relation("InternalNoteAuthor")
  notifications                Notification[]
  notificationPreferences      NotificationPreference[]
  privacyRequests              PrivacyRequest[]              @relation("PrivacyRequester")
  handledPrivacyRequests       PrivacyRequest[]              @relation("PrivacyHandler")
  privacyExecutionsVerified    PrivacyRequestExecution[]     @relation("PrivacyExecutionVerifier")
  privacyLegalHolds            PrivacyLegalHold[]            @relation("PrivacyHoldSubject")
  privacyLegalHoldsPlaced      PrivacyLegalHold[]            @relation("PrivacyHoldPlacer")
  privacyLegalHoldsReleased    PrivacyLegalHold[]            @relation("PrivacyHoldReleaser")
  requestedElevations          SupportElevation[]            @relation("ElevationActor")
  elevationSubjects            SupportElevation[]            @relation("ElevationSubject")
  approvedElevations           SupportElevation[]            @relation("ElevationApprover")
  treatmentEvents              TreatmentEvent[]              @relation("TreatmentEventActor")
  completedMilestones          TreatmentMilestone[]          @relation("MilestoneCompleter")
  treatmentInstructions        TreatmentInstruction[]        @relation("TreatmentInstructionAuthor")
  planChangeRequests           PlanChangeRequest[]           @relation("PlanChangeAuthor")
  planChangeAcknowledgements   PlanChangeAcknowledgement[]   @relation("PlanChangePatient")
  passportVersionsAuthored     DentalPassportVersion[]       @relation("PassportAuthor")
  passportVersionsPublished    DentalPassportVersion[]       @relation("PassportPublisher")
  secureSharesCreated          SecureShare[]                 @relation("SecureShareCreator")
  secureSharesRevoked          SecureShare[]                 @relation("SecureShareRevoker")
  incidentEvents               IncidentEvent[]               @relation("IncidentEventActor")
  createdIncidents             Incident[]                    @relation("IncidentCreator")
  ownedIncidents               Incident[]                    @relation("IncidentOwner")
  dentistProfile               Dentist?
  clinicStaffRecords           ClinicStaff[]
  idempotencyRecords           IdempotencyRecord[]
  fileAssets                   FileAsset[]
  treatmentAcceptances         TreatmentPlanAcceptance[]
  authoredReviews              Review[]                      @relation("ReviewPatient")
  reviewResponses              ReviewResponse[]              @relation("ReviewResponseAuthor")
  reviewAbuseReports           ReviewAbuseReport[]           @relation("ReviewReportAuthor")
  requestedRefunds             Refund[]                      @relation("RefundRequester")
  verificationCasesSubmitted   VerificationCase[]            @relation("VerificationCaseSubmitter")
  verificationCasesAssigned    VerificationCase[]            @relation("VerificationCaseReviewer")
  verificationEvidence         VerificationEvidence[]        @relation("VerificationEvidenceSubmitter")
  verificationApprovals        VerificationEvidence[]        @relation("VerificationEvidenceApprover")
  verificationReviews          VerificationReview[]          @relation("VerificationPrimaryReviewer")
  verificationSecondReviews    VerificationReview[]          @relation("VerificationSecondApprover")
  siteAuditsScheduled          SiteAudit[]                   @relation("SiteAuditScheduler")
  siteAuditsAssigned           SiteAudit[]                   @relation("SiteAuditAuditor")
  correctiveActionsRequested   CorrectiveAction[]            @relation("CorrectiveActionRequester")
  savedClinics                 SavedClinic[]
  matchingCriteriaAuthored     CaseMatchingCriteria[]        @relation("MatchingCriteriaAuthor")
  shortlistOverrides           CaseShortlistEntry[]          @relation("ShortlistOverrideAuthor")
  introductionRequests         IntroductionRequest[]         @relation("IntroductionPatient")
  introductionsHandled         IntroductionRequest[]         @relation("IntroductionHandler")
  conciergeAssignments         ConciergeCaseWorkspace[]      @relation("ConciergeAssignedAgent")
  conciergeSupervisions        ConciergeCaseWorkspace[]      @relation("ConciergeSupervisor")
  conciergeInternalNotes       ConciergeInternalNote[]       @relation("ConciergeNoteAuthor")
  conciergeTravelNotes         ConciergeTravelNote[]         @relation("ConciergeTravelNoteAuthor")
  conciergeCommunications      ConciergeCommunicationEvent[] @relation("ConciergeCommunicationActor")
  conciergeTasksAssigned       ConciergeTask[]               @relation("ConciergeTaskAssignee")
  conciergeTasksCreated        ConciergeTask[]               @relation("ConciergeTaskCreator")
  conciergeHandoffsFrom        ConciergeHandoff[]            @relation("ConciergeHandoffFrom")
  conciergeHandoffsTo          ConciergeHandoff[]            @relation("ConciergeHandoffTo")
  conciergeReviews             ConciergeSupervisorReview[]   @relation("ConciergeReviewAuthor")
  featureFlagVersions          FeatureFlagVersion[]          @relation("FeatureFlagVersionAuthor")
  notificationTemplateVersions NotificationTemplateVersion[] @relation("NotificationTemplateVersionAuthor")
  systemConfigurationVersions  SystemConfigurationVersion[]  @relation("SystemConfigurationVersionAuthor")
  contentPagesAuthored         ContentPage[]                 @relation("ContentPageAuthor")
  countryConfigurationsUpdated CountryConfiguration[]        @relation("CountryConfigurationUpdater")
  cityConfigurationsUpdated    CityConfiguration[]           @relation("CityConfigurationUpdater")
  localeConfigurationsUpdated  LocaleConfiguration[]         @relation("LocaleConfigurationUpdater")

  @@index([accountStatus, deletedAt])
  @@map("users")
}

model RoleDefinition {
  id           String                   @id @default(uuid()) @db.Uuid
  code         SystemRole               @unique
  displayName  String                   @map("display_name")
  isPrivileged Boolean                  @default(false) @map("is_privileged")
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  users        UserRole[]
  memberships  OrganizationMembership[]
  permissions  RolePermission[]

  @@map("role_definitions")
}

model PermissionDefinition {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  description String
  roles       RolePermission[]

  @@map("permission_definitions")
}

model RolePermission {
  roleId       String               @map("role_id") @db.Uuid
  permissionId String               @map("permission_id") @db.Uuid
  role         RoleDefinition       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   PermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String         @map("user_id") @db.Uuid
  roleId    String         @map("role_id") @db.Uuid
  grantedAt DateTime       @default(now()) @map("granted_at") @db.Timestamptz(6)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id                         String                      @id @default(uuid()) @db.Uuid
  userId                     String                      @map("user_id") @db.Uuid
  tokenHash                  String                      @unique @map("token_hash") @db.Char(64)
  expiresAt                  DateTime                    @map("expires_at") @db.Timestamptz(6)
  revokedAt                  DateTime?                   @map("revoked_at") @db.Timestamptz(6)
  mfaVerifiedAt              DateTime?                   @map("mfa_verified_at") @db.Timestamptz(6)
  lastSeenAt                 DateTime                    @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  ipAddressHash              String?                     @map("ip_address_hash") @db.Char(64)
  userAgent                  String?                     @map("user_agent") @db.VarChar(512)
  createdAt                  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  user                       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentRecords             ConsentRecord[]
  treatmentAcceptances       TreatmentPlanAcceptance[]
  planChangeAcknowledgements PlanChangeAcknowledgement[]
  introductionRequests       IntroductionRequest[]

  @@index([userId, revokedAt, expiresAt])
  @@map("sessions")
}

model MfaConfiguration {
  id                     String            @id @default(uuid()) @db.Uuid
  userId                 String            @map("user_id") @db.Uuid
  method                 String
  encryptedSecret        String?           @map("encrypted_secret")
  pendingEncryptedSecret String?           @map("pending_encrypted_secret")
  enabledAt              DateTime?         @map("enabled_at") @db.Timestamptz(6)
  revokedAt              DateTime?         @map("revoked_at") @db.Timestamptz(6)
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  recoveryCodes          MfaRecoveryCode[]

  @@unique([userId, method])
  @@index([userId, enabledAt, revokedAt])
  @@map("mfa_configurations")
}

model MfaRecoveryCode {
  id                 String           @id @default(uuid()) @db.Uuid
  mfaConfigurationId String           @map("mfa_configuration_id") @db.Uuid
  codeHash           String           @unique @map("code_hash") @db.Char(64)
  consumedAt         DateTime?        @map("consumed_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  mfaConfiguration   MfaConfiguration @relation(fields: [mfaConfigurationId], references: [id], onDelete: Cascade)

  @@index([mfaConfigurationId, consumedAt])
  @@map("mfa_recovery_codes")
}

model AccountLifecycleToken {
  id         String                    @id @default(uuid()) @db.Uuid
  userId     String                    @map("user_id") @db.Uuid
  type       AccountLifecycleTokenType
  tokenHash  String                    @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime                  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime?                 @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, consumedAt, expiresAt])
  @@map("account_lifecycle_tokens")
}

model Organization {
  id                  String                   @id @default(uuid()) @db.Uuid
  type                OrganizationType
  name                String
  slug                String                   @unique
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?                @map("deleted_at") @db.Timestamptz(6)
  memberships         OrganizationMembership[]
  clinic              Clinic?
  assignments         CaseAssignment[]
  auditLogs           AuditLog[]
  conciergeWorkspaces ConciergeCaseWorkspace[]

  @@index([type, deletedAt])
  @@map("organizations")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  roleId         String           @map("role_id") @db.Uuid
  status         MembershipStatus @default(INVITED)
  invitedAt      DateTime         @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  suspendedAt    DateTime?        @map("suspended_at") @db.Timestamptz(6)
  removedAt      DateTime?        @map("removed_at") @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           RoleDefinition   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  clinicStaff    ClinicStaff?

  @@unique([organizationId, userId, roleId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@map("organization_memberships")
}

model Clinic {
  id                 String                     @id @default(uuid()) @db.Uuid
  organizationId     String                     @unique @map("organization_id") @db.Uuid
  name               String
  slug               String                     @unique
  legalEntityName    String                     @map("legal_entity_name")
  verificationStatus VerificationStatus         @default(NOT_SUBMITTED) @map("verification_status")
  verifiedAt         DateTime?                  @map("verified_at") @db.Timestamptz(6)
  deletedAt          DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  locations          ClinicLocation[]
  affiliations       DentistClinicAffiliation[]
  treatmentPlans     TreatmentPlan[]
  matchingResults    MatchingResult[]
  verificationCases  VerificationCase[]
  appointments       Appointment[]
  reviews            Review[]
  incidents          Incident[]
  warrantyClaims     WarrantyClaim[]
  staff              ClinicStaff[]
  licenses           ProfessionalLicense[]
  services           ClinicService[]
  warrantyPolicies   WarrantyPolicy[]
  passportVersions   DentalPassportVersion[]
  siteAudits         SiteAudit[]
  discoveryProfile   ClinicDiscoveryProfile?
  savedByPatients    SavedClinic[]
  shortlistEntries   CaseShortlistEntry[]

  @@index([verificationStatus, verifiedAt])
  @@map("clinics")
}

model ClinicLocation {
  id                       String        @id @default(uuid()) @db.Uuid
  clinicId                 String        @map("clinic_id") @db.Uuid
  name                     String
  address                  String
  city                     String
  district                 String?
  timezone                 String
  encryptedBusinessContact String?       @map("encrypted_business_contact")
  active                   Boolean       @default(true)
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  clinic                   Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  staff                    ClinicStaff[]
  siteAudits               SiteAudit[]

  @@index([clinicId, active])
  @@index([city, district])
  @@map("clinic_locations")
}

model Dentist {
  id                String                     @id @default(uuid()) @db.Uuid
  userId            String?                    @unique @map("user_id") @db.Uuid
  slug              String                     @unique
  fullName          String                     @map("full_name")
  licenseNumber     String                     @unique @map("license_number")
  licenseStatus     VerificationStatus         @default(NOT_SUBMITTED) @map("license_status")
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  affiliations      DentistClinicAffiliation[]
  planVersions      TreatmentPlanVersion[]
  appointments      Appointment[]
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  licenses          ProfessionalLicense[]
  passportVersions  DentalPassportVersion[]
  verificationCases VerificationCase[]

  @@index([licenseStatus])
  @@map("dentists")
}

model DentistClinicAffiliation {
  id        String    @id @default(uuid()) @db.Uuid
  dentistId String    @map("dentist_id") @db.Uuid
  clinicId  String    @map("clinic_id") @db.Uuid
  active    Boolean   @default(true)
  startedAt DateTime  @map("started_at") @db.Timestamptz(6)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(6)
  dentist   Dentist   @relation(fields: [dentistId], references: [id], onDelete: Restrict)
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  @@index([clinicId, active])
  @@index([dentistId, active])
  @@map("dentist_clinic_affiliations")
}

model PatientProfile {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @unique @map("user_id") @db.Uuid
