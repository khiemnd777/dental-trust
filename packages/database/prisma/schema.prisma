  requiresWarranty   Boolean                @default(false) @map("requires_warranty")
  accessibilityNeeds String[]               @default([]) @map("accessibility_needs")
  preferredEquipment String[]               @default([]) @map("preferred_equipment")
  preferences        Json
  inputChecksum      String                 @map("input_checksum") @db.Char(64)
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  dentalCase         DentalCase             @relation(fields: [caseId], references: [id], onDelete: Restrict)
  createdBy          User                   @relation("MatchingCriteriaAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)
  matchingResults    MatchingResult[]

  @@unique([caseId, version])
  @@index([caseId, createdAt])
  @@map("case_matching_criteria")
}

model CaseShortlistEntry {
  id                      String               @id @default(uuid()) @db.Uuid
  caseId                  String               @map("case_id") @db.Uuid
  clinicId                String               @map("clinic_id") @db.Uuid
  matchingResultId        String               @map("matching_result_id") @db.Uuid
  organicRank             Int                  @map("organic_rank")
  displayedRank           Int                  @map("displayed_rank")
  status                  ShortlistStatus      @default(PROPOSED)
  encryptedOverrideReason String?              @map("encrypted_override_reason")
  overrideByUserId        String?              @map("override_by_user_id") @db.Uuid
  overriddenAt            DateTime?            @map("overridden_at") @db.Timestamptz(6)
  sharedAt                DateTime?            @map("shared_at") @db.Timestamptz(6)
  patientInterestedAt     DateTime?            @map("patient_interested_at") @db.Timestamptz(6)
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  dentalCase              DentalCase           @relation(fields: [caseId], references: [id], onDelete: Restrict)
  clinic                  Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  matchingResult          MatchingResult       @relation(fields: [matchingResultId], references: [id], onDelete: Restrict)
  overrideBy              User?                @relation("ShortlistOverrideAuthor", fields: [overrideByUserId], references: [id], onDelete: Restrict)
  introductionRequest     IntroductionRequest?

  @@unique([caseId, clinicId])
  @@index([caseId, status, displayedRank])
  @@map("case_shortlist_entries")
}

model IntroductionRequest {
  id                   String                    @id @default(uuid()) @db.Uuid
  shortlistEntryId     String                    @unique @map("shortlist_entry_id") @db.Uuid
  consentRecordId      String                    @map("consent_record_id") @db.Uuid
  patientUserId        String                    @map("patient_user_id") @db.Uuid
  sessionId            String                    @map("session_id") @db.Uuid
  handledByUserId      String?                   @map("handled_by_user_id") @db.Uuid
  status               IntroductionRequestStatus @default(REQUESTED)
  encryptedPatientNote String?                   @map("encrypted_patient_note")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  handledAt            DateTime?                 @map("handled_at") @db.Timestamptz(6)
  shortlistEntry       CaseShortlistEntry        @relation(fields: [shortlistEntryId], references: [id], onDelete: Restrict)
  consentRecord        ConsentRecord             @relation(fields: [consentRecordId], references: [id], onDelete: Restrict)
  patient              User                      @relation("IntroductionPatient", fields: [patientUserId], references: [id], onDelete: Restrict)
  session              Session                   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  handledBy            User?                     @relation("IntroductionHandler", fields: [handledByUserId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@map("introduction_requests")
}

model ConciergeCaseWorkspace {
  id                        String                        @id @default(uuid()) @db.Uuid
  caseId                    String                        @unique @map("case_id") @db.Uuid
  conciergeOrganizationId   String                        @map("concierge_organization_id") @db.Uuid
  assignedAgentUserId       String?                       @map("assigned_agent_user_id") @db.Uuid
  supervisorUserId          String?                       @map("supervisor_user_id") @db.Uuid
  priority                  ConciergePriority             @default(NORMAL)
  status                    ConciergeWorkStatus           @default(UNASSIGNED)
  slaDueAt                  DateTime                      @map("sla_due_at") @db.Timestamptz(6)
  encryptedPatientSummary   String?                       @map("encrypted_patient_summary")
  missingDocumentCategories String[]                      @default([]) @map("missing_document_categories")
  version                   Int                           @default(1)
  lastActivityAt            DateTime                      @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  createdAt                 DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  dentalCase                DentalCase                    @relation(fields: [caseId], references: [id], onDelete: Restrict)
  conciergeOrganization     Organization                  @relation(fields: [conciergeOrganizationId], references: [id], onDelete: Restrict)
  assignedAgent             User?                         @relation("ConciergeAssignedAgent", fields: [assignedAgentUserId], references: [id], onDelete: Restrict)
  supervisor                User?                         @relation("ConciergeSupervisor", fields: [supervisorUserId], references: [id], onDelete: Restrict)
  internalNotes             ConciergeInternalNote[]
  travelNotes               ConciergeTravelNote[]
  communications            ConciergeCommunicationEvent[]
  tasks                     ConciergeTask[]
  handoffs                  ConciergeHandoff[]
  supervisorReviews         ConciergeSupervisorReview[]

  @@index([conciergeOrganizationId, status, priority, slaDueAt])
  @@index([assignedAgentUserId, status, slaDueAt])
  @@map("concierge_case_workspaces")
}

model ConciergeInternalNote {
  id            String                 @id @default(uuid()) @db.Uuid
  workspaceId   String                 @map("workspace_id") @db.Uuid
  authorUserId  String                 @map("author_user_id") @db.Uuid
  encryptedBody String                 @map("encrypted_body")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace     ConciergeCaseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  author        User                   @relation("ConciergeNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@map("concierge_internal_notes")
}

model ConciergeTravelNote {
  id            String                 @id @default(uuid()) @db.Uuid
  workspaceId   String                 @map("workspace_id") @db.Uuid
  authorUserId  String                 @map("author_user_id") @db.Uuid
  encryptedBody String                 @map("encrypted_body")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace     ConciergeCaseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  author        User                   @relation("ConciergeTravelNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@map("concierge_travel_notes")
}

model ConciergeCommunicationEvent {
  id               String                          @id @default(uuid()) @db.Uuid
  workspaceId      String                          @map("workspace_id") @db.Uuid
  actorUserId      String                          @map("actor_user_id") @db.Uuid
  channel          ConciergeCommunicationChannel
  direction        ConciergeCommunicationDirection
  encryptedSummary String                          @map("encrypted_summary")
  occurredAt       DateTime                        @map("occurred_at") @db.Timestamptz(6)
  createdAt        DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace        ConciergeCaseWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  actor            User                            @relation("ConciergeCommunicationActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, occurredAt])
  @@map("concierge_communication_events")
}

model ConciergeTask {
  id               String                 @id @default(uuid()) @db.Uuid
  workspaceId      String                 @map("workspace_id") @db.Uuid
  kind             ConciergeTaskKind
  status           ConciergeTaskStatus    @default(TODO)
  encryptedTitle   String                 @map("encrypted_title")
  encryptedDetails String?                @map("encrypted_details")
  assignedUserId   String?                @map("assigned_user_id") @db.Uuid
  createdByUserId  String                 @map("created_by_user_id") @db.Uuid
  dueAt            DateTime               @map("due_at") @db.Timestamptz(6)
  completedAt      DateTime?              @map("completed_at") @db.Timestamptz(6)
  version          Int                    @default(1)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace        ConciergeCaseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  assignedUser     User?                  @relation("ConciergeTaskAssignee", fields: [assignedUserId], references: [id], onDelete: Restrict)
  createdBy        User                   @relation("ConciergeTaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status, dueAt])
  @@index([assignedUserId, status, dueAt])
  @@map("concierge_tasks")
}

model ConciergeHandoff {
  id              String                 @id @default(uuid()) @db.Uuid
  workspaceId     String                 @map("workspace_id") @db.Uuid
  fromUserId      String                 @map("from_user_id") @db.Uuid
  toUserId        String                 @map("to_user_id") @db.Uuid
  encryptedReason String                 @map("encrypted_reason")
  status          ConciergeHandoffStatus @default(PENDING)
  requestId       String                 @map("request_id") @db.VarChar(128)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  acceptedAt      DateTime?              @map("accepted_at") @db.Timestamptz(6)
  workspace       ConciergeCaseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  fromUser        User                   @relation("ConciergeHandoffFrom", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser          User                   @relation("ConciergeHandoffTo", fields: [toUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status, createdAt])
  @@index([toUserId, status, createdAt])
  @@map("concierge_handoffs")
}

model ConciergeSupervisorReview {
  id               String                  @id @default(uuid()) @db.Uuid
  workspaceId      String                  @map("workspace_id") @db.Uuid
  reviewerUserId   String                  @map("reviewer_user_id") @db.Uuid
  decision         ConciergeReviewDecision
  encryptedNote    String                  @map("encrypted_note")
  workspaceVersion Int                     @map("workspace_version")
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace        ConciergeCaseWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  reviewer         User                    @relation("ConciergeReviewAuthor", fields: [reviewerUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@map("concierge_supervisor_reviews")
}
