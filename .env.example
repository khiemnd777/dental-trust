# Dental Trust local-development environment
#
# Copy this file to .env. Values below are development-only. Never reuse them
# in staging or production. Production secrets must come from the deployment
# platform's secret manager.

NODE_ENV=development
PORT=4000
WORKER_HEALTH_PORT=4001
LOG_LEVEL=debug

# Server and browser origins
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
CARE_APP_URL=http://localhost:3000
PROVIDER_APP_URL=http://localhost:3001
OPERATIONS_APP_URL=http://localhost:3002
PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_DEFAULT_LOCALE=vi-VN
NEXT_PUBLIC_BUILD_VERSION=development

# PostgreSQL / Prisma
POSTGRES_USER=dental_trust
POSTGRES_PASSWORD=dental_trust_dev_only
POSTGRES_DB=dental_trust
DATABASE_URL=postgresql://dental_trust:dental_trust_dev_only@localhost:5432/dental_trust?schema=public
DIRECT_DATABASE_URL=postgresql://dental_trust:dental_trust_dev_only@localhost:5432/dental_trust?schema=public

# Redis / background jobs
REDIS_URL=redis://localhost:6379

# Authentication. Replace both values before sharing a local environment.
# Production values must be generated from a cryptographically secure source.
AUTH_SECRET=development-only-change-me-32-bytes-minimum
AUTH_ISSUER=dental-trust
AUTH_AUDIENCE=dental-trust-web
WEB_AUTH_ADAPTER=api

# Application-level encryption for sensitive fields. Generate a unique secret
# with at least 32 high-entropy characters per environment.
FIELD_ENCRYPTION_KEY=development-only-field-key-change-me
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT_MS=15000
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_AUDIO_TIMEOUT_MS=30000

# S3-compatible private object storage (MinIO locally)
MINIO_ROOT_USER=dentaltrust
MINIO_ROOT_PASSWORD=dentaltrust-dev-only
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_BUCKET=dental-trust-private
S3_ACCESS_KEY=dentaltrust
S3_SECRET_KEY=dentaltrust-dev-only
S3_FORCE_PATH_STYLE=true

# Malware scanning
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Transactional email (Mailpit locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=care@dentaltrust.local
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional outbound providers. Production endpoints must use HTTPS and are
# enabled only when both the endpoint and bearer token are present.
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
MESSAGING_PROVIDER_URL=
MESSAGING_PROVIDER_TOKEN=

# Payments. The development adapter never represents production success.
PAYMENT_ADAPTER=development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Video meetings. Production requires manual plus an explicit HTTPS host allowlist.
MEETING_ADAPTER=development
MEETING_ALLOWED_HOSTS=

# Calendar synchronization. Production requires an HTTPS provider service.
CALENDAR_ADAPTER=development
CALENDAR_PROVIDER_URL=
CALENDAR_PROVIDER_TOKEN=
PRIVACY_EXPORT_TTL_HOURS=72
PRIVACY_EXPORT_MAX_BYTES=536870912

# Dental Passport PDF. `builtin` embeds the bundled OFL Noto Sans font.
# `external` fails closed unless both service values are configured; production URLs must use HTTPS.
PASSPORT_PDF_ADAPTER=builtin
PASSPORT_PDF_SERVICE_URL=
PASSPORT_PDF_SERVICE_TOKEN=

# Observability adapters. Console/no-op adapters are allowed only outside prod.
OTEL_EXPORTER_OTLP_ENDPOINT=
ERROR_TRACKING_DSN=
