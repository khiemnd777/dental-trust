{
  "name": "@dental-trust/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@aws-sdk/s3-request-presigner": "3.1085.0",
    "@dental-trust/auth": "workspace:*",
    "@dental-trust/config": "workspace:*",
    "@dental-trust/contracts": "workspace:*",
    "@dental-trust/database": "workspace:*",
    "@dental-trust/domain": "workspace:*",
    "@dental-trust/observability": "workspace:*",
    "@dental-trust/security": "workspace:*",
    "@dental-trust/validation": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/throttler": "6.5.0",
    "argon2": "0.45.0",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "pdfkit": "0.19.1",
    "pino": "9.14.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "stripe": "18.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dental-trust/testing": "workspace:*",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/pdfkit": "0.17.6",
    "@types/supertest": "6.0.3",
    "supertest": "7.2.2",
    "tsx": "4.20.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
